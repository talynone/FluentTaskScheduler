<ContentDialog
    x:Class="FluentTaskScheduler.Dialogs.WhatsNewDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    CloseButtonText="Got it"
    DefaultButton="Close"
    CornerRadius="16"
    RequestedTheme="Dark">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">660</x:Double>
        <x:Double x:Key="ContentDialogMinWidth">500</x:Double>
        <!-- Rounded corners -->
        <CornerRadius x:Key="OverlayCornerRadius">16</CornerRadius>
    </ContentDialog.Resources>

    <StackPanel Spacing="16" MaxWidth="600">

        <!-- Header: icon + title + version badge -->
        <Grid ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sparkle icon -->
            <Border Width="52" Height="52" CornerRadius="14"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    VerticalAlignment="Top">
                <FontIcon Glyph="&#xE946;" FontSize="26"
                          Foreground="White"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Title + version badge -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                <TextBlock x:Name="ReleaseTitleText"
                           FontSize="17" FontWeight="SemiBold"
                           TextWrapping="Wrap" LineHeight="24"/>

                <!-- Prominent version badge -->
                <Border x:Name="VersionBadge"
                        Background="{ThemeResource AccentFillColorTertiaryBrush}"
                        CornerRadius="6" Padding="8,3"
                        HorizontalAlignment="Left">
                    <TextBlock x:Name="ReleaseTagText"
                               FontSize="12" FontWeight="SemiBold"
                               FontFamily="Consolas"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                </Border>
            </StackPanel>
        </Grid>

        <MenuFlyoutSeparator Opacity="0.4"/>

        <!-- Scrollable Markdown release notes -->
        <ScrollViewer MaxHeight="360" HorizontalScrollMode="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <RichTextBlock x:Name="ReleaseBodyRtb"
                           TextWrapping="Wrap"
                           FontSize="13"
                           LineHeight="22"
                           IsTextSelectionEnabled="True"/>
        </ScrollViewer>

        <!-- Footer: GitHub link -->
        <HyperlinkButton x:Name="ViewOnGitHubButton"
                         HorizontalAlignment="Left"
                         Padding="0">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE8A7;" FontSize="13"/>
                <TextBlock Text="View full release on GitHub" FontSize="13"/>
            </StackPanel>
        </HyperlinkButton>

    </StackPanel>
</ContentDialog>
