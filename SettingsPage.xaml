<Page
    x:Class="FluentTaskScheduler.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" Padding="24,12,24,12">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <Button x:Name="BackButton" Click="BackButton_Click" Background="Transparent" BorderThickness="0" Width="40" Height="40" CornerRadius="5" ToolTipService.ToolTip="Go Back">
                    <FontIcon Glyph="&#xE72B;"/>
                </Button>
                <TextBlock x:Uid="SettingsHeader" Text="Settings" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer x:Name="PageScrollViewer" Grid.Row="1" Padding="24" IsScrollInertiaEnabled="False">
            <StackPanel Spacing="24" MaxWidth="600" HorizontalAlignment="Left">
                
                <!-- Appearance -->
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="AppearanceHeader" Text="Appearance" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    
                    <TextBlock Text="App Theme: Dark (Fixed)" Style="{StaticResource BodyTextBlockStyle}" Margin="0,8,0,0"/>

                    <ToggleSwitch x:Name="MicaModeToggle" Header="Mica Effect" OffContent="Off" OnContent="On" Toggled="MicaModeToggle_Toggled" IsOn="True" Margin="0,8,0,0"/>

                    <ToggleSwitch x:Name="OledModeToggle" x:Uid="OledToggle" Header="OLED Mode" OffContent="Standard Dark" OnContent="Pure Black (Power Saving)" Toggled="OledModeToggle_Toggled" IsOn="True" Margin="0,8,0,0"/>
                    <TextBlock x:Uid="OledHint" Text="OLED mode uses pure black backgrounds for power saving." Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" Margin="0,-4,0,0"/>
                </StackPanel>

                <!-- Behaviors -->
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="BehaviorsHeader" Text="Behaviors" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    
                    <ToggleSwitch x:Name="NotificationsToggle" x:Uid="NotificationsToggle" Header="Task Notifications" OnContent="On" OffContent="Off" IsOn="True"/>
                    <TextBlock Text="Show a toast notification when a task starts or fails." Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" Margin="0,-4,0,0"/>

                    <ToggleSwitch x:Name="TrayIconToggle" x:Uid="TrayIconToggle" Header="System Tray" OnContent="On" OffContent="Off" IsOn="True" Margin="0,8,0,0"/>
                    <CheckBox x:Name="MinimizeToTrayCheck" Content="Minimize to tray instead of closing" IsChecked="True" Margin="0,-4,0,0"/>

                    <ToggleSwitch x:Name="RunOnStartupToggle" Header="Run on Startup" OnContent="On" OffContent="Off" IsOn="False" Margin="0,8,0,0"/>
                    <TextBlock Text="Automatically start the app when you log in to Windows." Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" Margin="0,-4,0,0"/>

                    <ToggleSwitch x:Name="SmoothScrollingToggle" Header="Smooth Scrolling" OnContent="On" OffContent="Off" IsOn="False" Margin="0,8,0,0"/>
                    <TextBlock Text="Enable smooth inertia-based scrolling throughout the app." Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" Margin="0,-4,0,0"/>
                </StackPanel>

                <!-- Logging -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Logging" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <ToggleSwitch x:Name="LoggingToggle" Header="Application Logging" OnContent="On" OffContent="Off" IsOn="True"/>
                    <TextBlock Text="Write internal events and errors to a log file for troubleshooting." Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" Margin="0,-4,0,0"/>
                    <Button x:Name="OpenLogButton" Content="Open Log File" Click="OpenLogButton_Click" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- General -->
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="GeneralHeader" Text="General" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <ToggleSwitch x:Name="ConfirmDeleteToggle" x:Uid="ConfirmDelete" Header="Confirm Task Deletion" OnContent="On" OffContent="Off" Toggled="ConfirmDeleteToggle_Toggled"/>
                </StackPanel>

                <!-- Backup & Restore -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Backup &amp; Restore" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="Export your current settings to a file, or restore from a backup." Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="ExportSettingsButton" Content="Export Settings" Click="ExportSettings_Click"/>
                        <Button x:Name="ImportSettingsButton" Content="Import Settings" Click="ImportSettings_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- About -->
                <StackPanel Spacing="8" Margin="0,24,0,0">
                    <TextBlock x:Uid="AboutHeader" Text="About" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock x:Uid="AboutTitle" Text="Fluent Task Scheduler" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock x:Uid="AboutVersion" Text="Version 1.4.0" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                    <TextBlock x:Uid="AboutBuilt" Text="Built with WinUI 3" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                </StackPanel>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
